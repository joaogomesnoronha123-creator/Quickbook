rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['name', 'createdAt']) && 
               data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
               data.createdAt == (resource == null ? request.time : resource.data.createdAt);
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'lastActive', 'email', 'isAnonymous', 'isLinked']);
    }

    // Library Rules
    match /users/{userId}/library/{bookId} {
      function isValidBook(data) {
        return data.keys().hasAll(['title', 'author', 'summary', 'ownerId', 'createdAt']) && 
               data.keys().size() == 5 &&
               data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
               data.author is string && data.author.size() > 0 && data.author.size() < 500 &&
               data.summary is string && data.summary.size() > 0 &&
               data.ownerId == request.auth.uid &&
               data.createdAt == (resource == null ? request.time : resource.data.createdAt);
      }

      function isValidId(id) {
        return id is string && id.size() > 0 && id.size() <= 128;
      }

      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidBook(incoming());
      allow update: if isOwner(userId) && 
                      isValidBook(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'author', 'summary']);
      allow delete: if isOwner(userId);

      // Chat subcollection
      match /chat/{messageId} {
        function isValidChatMessage(data) {
          return data.keys().hasAll(['role', 'text', 'timestamp']) &&
                 data.keys().size() == 3 &&
                 data.role in ['user', 'model'] &&
                 data.text is string && data.text.size() > 0 &&
                 data.timestamp == (resource == null ? request.time : resource.data.timestamp);
        }

        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidChatMessage(incoming()) && isValidId(messageId);
        // Messages are usually immutable in this app
      }
    }
  }
}
