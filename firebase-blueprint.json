{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "isAnonymous": { "type": "boolean" },
        "isLinked": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "Book": {
      "title": "Saved Book/Study",
      "description": "A book summary and its related chat history",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "summary": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "author", "summary", "ownerId", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in a study chat",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Main user profiles"
    },
    "/users/{userId}/library/{bookId}": {
      "schema": "Book",
      "description": "Collection of books/summaries for a user"
    },
    "/users/{userId}/library/{bookId}/chat/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat messages related to a specific book"
    }
  }
}
